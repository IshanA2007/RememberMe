# RememberMe Backend — Environment Configuration
# Copy to `.env` and fill in real values. Do NOT commit `.env`.
# See docs/SERVICE_BACKEND.md §5 for the authoritative env var table.

# --- Server ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=5000

# --- Storage ---
SQLITE_PATH=./data/rememberme.db

# --- Auth0 ---
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://rememberme.app/api
AUTH0_ROLE_CLAIM=https://rememberme.app/role

# --- ElevenLabs ---
ELEVENLABS_API_KEY=replace-with-elevenlabs-key
ELEVENLABS_DEFAULT_VOICE_ID=replace-with-voice-id

# --- LLM (Anthropic) ---
LLM_API_KEY=replace-with-anthropic-key
LLM_MODEL=claude-sonnet-4-5

# --- Recognition tuning ---
RECOGNITION_THRESHOLD=0.50
RECOGNITION_MARGIN=0.05
CACHE_REFRESH_SECONDS=30

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# --- Dev-mode auth bypass (hackathon only; NEVER default to true) ---
BACKEND_DEV_AUTH_BYPASS=false
